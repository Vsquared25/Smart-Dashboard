generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Course {
  id         Int      @id @default(autoincrement())
  code       String
  name       String
  instructor String
  credits    Int
  createdAt  DateTime @default(now())
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  course    String
  dueDate   DateTime
  priority  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model StudyPlan {
  id             Int      @id @default(autoincrement())
  course         String
  goal           String
  deadline       DateTime
  availableHours Float
  difficulty     String
  plan           String
  source         String
  createdAt      DateTime @default(now())
}

model JobApplication {
  id          Int      @id @default(autoincrement())
  company     String
  role        String
  location    String
  appliedDate DateTime
  status      String
  createdAt   DateTime @default(now())
}