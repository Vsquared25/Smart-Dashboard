generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Course {
  id         Int      @id @default(autoincrement())
  code       String
  name       String
  instructor String
  credits    Int
  createdAt  DateTime @default(now())
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  course    String
  dueDate   DateTime
  priority  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
}